{
  "env": {
    "cypress/globals": true,
    "node": true
  },
  "extends": ["plugin:cypress/recommended"],
  "plugins": ["cypress"],
  "rules": {
    "no-console": "off",
    "no-namespace": "off",
    "no-redeclare": "off",
    "@typescript-eslint/no-var-requires": "off",
    "@typescript-eslint/no-namespace": "off"
  }
}
